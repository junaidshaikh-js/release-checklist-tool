// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Release {
  id             String            @id @default(uuid())
  name           String
  date           DateTime
  status         String            @default("planned")
  additionalInfo String?
  checklist      ReleaseChecklist?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
}

model ReleaseChecklist {
  id                   String   @id @default(uuid())
  releaseId            String   @unique
  prMerged             Boolean  @default(false)
  changelogUpdated     Boolean  @default(false)
  testsPassing         Boolean  @default(false)
  githubReleaseCreated Boolean  @default(false)
  deployedToDemo       Boolean  @default(false)
  testedInDemo         Boolean  @default(false)
  deployedToProd       Boolean  @default(false)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  release Release @relation(fields: [releaseId], references: [id], onDelete: Cascade)
}
